{
  "name": "campus-marketplace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "workspaces": {
    "packages": [
      "./packages/common",
      "./packages/apps/*"
    ],
    "nohoist": []
  },
  "scripts": {
    "dev:front": "pnpm --filter campus-commonprovide build && concurrently -k -n commonprovide,shell,portal,ops \"pnpm --filter campus-commonprovide preview\" \"pnpm --filter campus-shell dev\" \"pnpm --filter campus-portal dev\" \"pnpm --filter campus-ops dev\"",
    "dev:all": "pnpm dev:front",
    "dev:shell": "pnpm --filter campus-shell dev",
    "dev:portal": "pnpm --filter campus-portal dev",
    "dev:ops": "pnpm --filter campus-ops dev",
    "dev:commonprovide": "pnpm --filter campus-commonprovide dev",
    "build:front": "pnpm -r --filter campus-* build"
  },
  "devDependencies": {
    "@arco-design/web-vue": "^2.56.2",
    "@originjs/vite-plugin-federation": "^1.3.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "axios": "^1.7.9",
    "concurrently": "^9.1.2",
    "less": "^4.6.4",
    "sass": "^1.86.3",
    "pinia": "^2.1.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vite": "^6.4.2",
    "qiankun": "2.10.16"
  }
}
